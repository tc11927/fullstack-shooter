<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0" />
        <title>
            <%= typeof title !== 'undefined' ? title + ' | ' : '' %>Robotron
        </title>
        <link
            rel="stylesheet"
            href="/css/styles.css" />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/assets/player.svg?v=2" />
        <link
            rel="shortcut icon"
            type="image/svg+xml"
            href="/assets/player.svg?v=2" />
    </head>
    <body>
        <nav class="navbar">
            <div class="nav-container">
                <a
                    href="/"
                    class="nav-logo">
                    <span class="logo-text">ROBOTRON</span>
                </a>
                <div class="nav-links">
                    <a
                        href="/scoreboard"
                        class="nav-link"
                        >Scoreboard</a
                    >
                    <% if (user) { %>
                    <a
                        href="/game"
                        class="nav-link"
                        >Play</a
                    >
                    <span class="nav-user"
                        >Welcome, <strong><%= user.username %></strong></span
                    >
                    <a
                        href="/logout"
                        class="nav-link nav-btn"
                        >Logout</a
                    >
                    <% } else { %>
                    <a
                        href="/login"
                        class="nav-link"
                        >Login</a
                    >
                    <a
                        href="/signup"
                        class="nav-link nav-btn"
                        >Sign Up</a
                    >
                    <% } %>
                </div>
            </div>
        </nav>
        <main class="main-content"></main>
    </body>
</html>
